    ex:priority "Medium" ;
    ex:requirementForCareer ex:DataAnalyst ;
    ex:requiresSkill ex:ProblemSolving .

ex:DataAnalyst_Python_Requirement a ex:SkillRequirement ;
    ex:priority "High" ;
    ex:requirementForCareer ex:DataAnalyst ;
    ex:requiresSkill ex:Python .

ex:DataAnalyst_SQL_Requirement a ex:SkillRequirement ;
    ex:priority "High" ;
    ex:requirementForCareer ex:DataAnalyst ;
    ex:requiresSkill ex:SQL .

ex:DataAnalyst_Statistics_Requirement a ex:SkillRequirement ;
    ex:priority "High" ;
    ex:requirementForCareer ex:DataAnalyst ;
