ex:SoftwareDeveloper_ProblemSolving_Requirement a ex:SkillRequirement ;
    ex:priority "Medium" ;
    ex:requirementForCareer ex:SoftwareDeveloper ;
    ex:requiresSkill ex:ProblemSolving .

ex:SoftwareDeveloper_Python_Requirement a ex:SkillRequirement ;
    ex:priority "High" ;
    ex:requirementForCareer ex:SoftwareDeveloper ;
    ex:requiresSkill ex:Python .

ex:SoftwareDeveloper_SQL_Requirement a ex:SkillRequirement ;
    ex:priority "Medium" ;
    ex:requirementForCareer ex:SoftwareDeveloper ;
    ex:requiresSkill ex:SQL .

ex:SoftwareDeveloper_WebDevelopment_Requirement a ex:SkillRequirement ;
