@prefix ex: <http://example.org/career-skill#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Career a rdfs:Class .

ex:Course a rdfs:Class .

ex:Skill a rdfs:Class .

ex:SkillRequirement a rdfs:Class .

ex:Source a rdfs:Class .

ex:Student a rdfs:Class .

ex:DataVisualizationFundamentals a ex:Course ;
    ex:courseName "Data Visualization Fundamentals" ;
    ex:prerequisiteSkill ex:Statistics ;
    ex:teachesSkill ex:DataVisualization .

ex:DatabaseSystems a ex:Course ;
    ex:courseName "Database Systems" ;
    ex:teachesSkill ex:DatabaseManagement,
        ex:SQL .

ex:MachineLearningFundamentals a ex:Course ;
    ex:courseName "Machine Learning Fundamentals" ;
    ex:prerequisiteSkill ex:Python,
        ex:Statistics ;
    ex:teachesSkill ex:MachineLearning .

ex:NetworkSecurity a ex:Course ;
    ex:courseName "Network Security" ;
    ex:teachesSkill ex:Cybersecurity,
        ex:Networking .

ex:ProblemSolvingforComputing a ex:Course ;
    ex:courseName "Problem Solving for Computing" ;
    ex:teachesSkill ex:ProblemSolving .

ex:PythonProgramming a ex:Course ;
    ex:courseName "Python Programming" ;
    ex:teachesSkill ex:Python .

ex:S001 a ex:Student ;
    ex:hasSkill ex:Python,
        ex:SQL ;
    ex:studentName "Sample Student" ;
    ex:targetsCareer ex:AIEngineer .

ex:StatisticsforDataAnalytics a ex:Course ;
    ex:courseName "Statistics for Data Analytics" ;
    ex:teachesSkill ex:Statistics .

ex:WebApplicationDevelopment a ex:Course ;
    ex:courseName "Web Application Development" ;
    ex:prerequisiteSkill ex:Python ;
    ex:teachesSkill ex:WebDevelopment .

ex:alias a rdf:Property ;
    rdfs:label "Skill alias" .

ex:careerLevel a rdf:Property ;
    rdfs:label "Career level" .

ex:careerName a rdf:Property ;
    rdfs:label "Career name" .

ex:courseName a rdf:Property ;
    rdfs:label "Course name" .

ex:description a rdf:Property ;
    rdfs:label "Description" .

ex:hasRequirement a rdf:Property ;
    rdfs:label "Career has a skill requirement record" .

ex:hasSkill a rdf:Property ;
    rdfs:label "Student has a skill" .

ex:prerequisiteSkill a rdf:Property ;
    rdfs:label "Course has a prerequisite skill" .

ex:priority a rdf:Property ;
    rdfs:label "Skill priority" .

ex:requirementForCareer a rdf:Property ;
    rdfs:label "Skill requirement belongs to a career" .

ex:requiresSkill a rdf:Property ;
    rdfs:label "Career requires a skill" .

ex:skillCategory a rdf:Property ;
    rdfs:label "Skill category" .

ex:skillName a rdf:Property ;
    rdfs:label "Skill name" .

ex:sourceName a rdf:Property ;
    rdfs:label "Source name" .

ex:sourceNote a rdf:Property ;
    rdfs:label "Source mapping note" .

ex:sourceOccupationCode a rdf:Property ;
    rdfs:label "O*NET occupation code" .

ex:sourceOccupationTitle a rdf:Property ;
    rdfs:label "O*NET occupation title" .

ex:sourceUrl a rdf:Property ;
    rdfs:label "Source URL" .

ex:studentName a rdf:Property ;
    rdfs:label "Student name" .

ex:targetsCareer a rdf:Property ;
    rdfs:label "Student targets a career" .

ex:teachesSkill a rdf:Property ;
    rdfs:label "Course teaches a skill" .

ex:usesSource a rdf:Property ;
    rdfs:label "Career uses a data source" .

ex:AIEngineer_DataVisualization_Requirement a ex:SkillRequirement ;
    ex:priority "Medium" ;
    ex:requirementForCareer ex:AIEngineer ;
    ex:requiresSkill ex:DataVisualization .

ex:AIEngineer_MachineLearning_Requirement a ex:SkillRequirement ;
    ex:priority "High" ;
    ex:requirementForCareer ex:AIEngineer ;
    ex:requiresSkill ex:MachineLearning .

