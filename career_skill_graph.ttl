ex:CloudArchitect a ex:Career ;
    ex:careerLevel "Advanced" ;
    ex:careerName "Cloud Architect" ;
    ex:hasRequirement ex:CloudArchitect_CloudComputing_Requirement,
        ex:CloudArchitect_DevOps_Requirement,
        ex:CloudArchitect_Networking_Requirement,
        ex:CloudArchitect_ProblemSolving_Requirement ;
    ex:requiresSkill ex:CloudComputing,
        ex:DevOps,
        ex:Networking,
        ex:ProblemSolving ;
    ex:sourceNote "Cloud Architect is represented using the O*NET Computer Systems Analysts occupation. Required skills focus on Cloud Computing, DevOps, Networking, and Essential Problem Solving." ;
    ex:sourceOccupationCode "15-1211.00" ;
    ex:sourceOccupationTitle "Computer Systems Analysts" ;
    ex:usesSource ex:SRC001 .

