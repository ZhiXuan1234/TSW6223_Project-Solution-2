    ex:priority "High" ;
    ex:requirementForCareer ex:AIEngineer ;
    ex:requiresSkill ex:Python .

ex:AIEngineer_Statistics_Requirement a ex:SkillRequirement ;
    ex:priority "High" ;
    ex:requirementForCareer ex:AIEngineer ;
    ex:requiresSkill ex:Statistics .

ex:CybersecurityAnalyst_Cybersecurity_Requirement a ex:SkillRequirement ;
