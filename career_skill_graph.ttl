ex:Cybersecurity a ex:Skill ;
    ex:alias "cyber security",
        "cybersecurity",
        "information security",
        "security" ;
    ex:skillCategory "Technical" ;
    ex:skillName "Cybersecurity" .

ex:DatabaseManagement a ex:Skill ;
    ex:alias "database",
        "database management",
        "database systems",
        "dbms" ;
    ex:skillCategory "Technical" ;
    ex:skillName "Database Management" .

ex:MachineLearning a ex:Skill ;
    ex:alias "machien learning",
        "machine learning",
        "ml" ;
    ex:skillCategory "Technical" ;
    ex:skillName "Machine Learning" .

ex:Networking a ex:Skill ;
    ex:alias "computer network",
        "computer networking",
        "network",
        "networking" ;
    ex:skillCategory "Technical" ;
    ex:skillName "Networking" .

ex:WebDevelopment a ex:Skill ;
    ex:alias "front end",
        "frontend",
        "html css javascript",
        "web development" ;
    ex:skillCategory "Technical" ;
    ex:skillName "Web Development" .

ex:CybersecurityAnalyst a ex:Career ;
    ex:careerLevel "Intermediate" ;
    ex:careerName "Cybersecurity Analyst" ;
    ex:hasRequirement ex:CybersecurityAnalyst_Cybersecurity_Requirement,
        ex:CybersecurityAnalyst_Networking_Requirement,
        ex:CybersecurityAnalyst_ProblemSolving_Requirement,
        ex:CybersecurityAnalyst_SQL_Requirement ;
    ex:requiresSkill ex:Cybersecurity,
        ex:Networking,
        ex:ProblemSolving,
        ex:SQL ;
    ex:sourceNote "Cybersecurity Analyst is represented using the closest O*NET occupation, Information Security Analysts, because O*NET uses official occupation titles rather than every informal job-market title." ;
    ex:sourceOccupationCode "15-1212.00" ;
    ex:sourceOccupationTitle "Information Security Analysts" ;
    ex:usesSource ex:SRC001 .

ex:SRC001 a ex:Source ;
    ex:description "Used as a real-world reference for occupation descriptions, worker requirements, software skills, essential skills, and career-skill relationships." ;
    ex:sourceName "O*NET OnLine" ;
    ex:sourceUrl "https://www.onetonline.org/" .

ex:DataAnalyst a ex:Career ;
    ex:careerLevel "Intermediate" ;
    ex:careerName "Data Analyst" ;
    ex:hasRequirement ex:DataAnalyst_DataVisualization_Requirement,
        ex:DataAnalyst_ProblemSolving_Requirement,
        ex:DataAnalyst_Python_Requirement,
        ex:DataAnalyst_SQL_Requirement,
        ex:DataAnalyst_Statistics_Requirement ;
    ex:requiresSkill ex:DataVisualization,
        ex:ProblemSolving,
        ex:Python,
        ex:SQL,
        ex:Statistics ;
    ex:sourceNote "Data Analyst is represented using O*NET Data Scientists as a close data-related occupation for this prototype because O*NET search maps data analyst-related work to data science and business intelligence roles." ;
    ex:sourceOccupationCode "15-2051.00" ;
    ex:sourceOccupationTitle "Data Scientists" ;
    ex:usesSource ex:SRC001 .

ex:DataVisualization a ex:Skill ;
    ex:alias "dashboard",
        "data visualisation",
        "data visualization",
        "visualization" ;
    ex:skillCategory "Technical" ;
    ex:skillName "Data Visualization" .

ex:SoftwareDeveloper a ex:Career ;
    ex:careerLevel "Intermediate" ;
    ex:careerName "Software Developer" ;
    ex:hasRequirement ex:SoftwareDeveloper_DatabaseManagement_Requirement,
        ex:SoftwareDeveloper_ProblemSolving_Requirement,
        ex:SoftwareDeveloper_Python_Requirement,
        ex:SoftwareDeveloper_SQL_Requirement,
        ex:SoftwareDeveloper_WebDevelopment_Requirement ;
    ex:requiresSkill ex:DatabaseManagement,
        ex:ProblemSolving,
        ex:Python,
        ex:SQL,
        ex:WebDevelopment ;
    ex:sourceNote "Software Developer is directly mapped to O*NET Software Developers. The selected skills reflect programming, development environment software, database-related tools, web platform development software, and essential problem-solving skills shown in O*NET worker requirements." ;
    ex:sourceOccupationCode "15-1252.00" ;
    ex:sourceOccupationTitle "Software Developers" ;
    ex:usesSource ex:SRC001 .

ex:AIEngineer a ex:Career ;
    ex:careerLevel "Advanced" ;
    ex:careerName "AI Engineer" ;
    ex:hasRequirement ex:AIEngineer_DataVisualization_Requirement,
        ex:AIEngineer_MachineLearning_Requirement,
        ex:AIEngineer_ProblemSolving_Requirement,
        ex:AIEngineer_Python_Requirement,
        ex:AIEngineer_Statistics_Requirement ;
    ex:requiresSkill ex:DataVisualization,
        ex:MachineLearning,
        ex:ProblemSolving,
        ex:Python,
        ex:Statistics ;
    ex:sourceNote "AI Engineer is represented using the closest O*NET occupation, Computer and Information Research Scientists, because O*NET does not list AI Engineer as a direct main occupation title." ;
    ex:sourceOccupationCode "15-1221.00" ;
    ex:sourceOccupationTitle "Computer and Information Research Scientists" ;
    ex:usesSource ex:SRC001 .

ex:Statistics a ex:Skill ;
    ex:alias "statistic",
        "statistics",
        "stats" ;
    ex:skillCategory "Technical" ;
    ex:skillName "Statistics" .

ex:SQL a ex:Skill ;
    ex:alias "database query",
        "sql",
        "structured query language" ;
    ex:skillCategory "Technical" ;
    ex:skillName "SQL" .

ex:ProblemSolving a ex:Skill ;
    ex:alias "analytical thinking",
        "critical thinking",
        "problem solving",
        "problem-solving" ;
    ex:skillCategory "Essential" ;
    ex:skillName "Problem Solving" .

ex:Python a ex:Skill ;
    ex:alias "py",
        "pyhton",
        "python",
        "python programming" ;
    ex:skillCategory "Technical" ;
    ex:skillName "Python" .

