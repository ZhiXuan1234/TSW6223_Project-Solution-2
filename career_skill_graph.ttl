    ex:priority "Medium" ;
    ex:requirementForCareer ex:CybersecurityAnalyst ;
    ex:requiresSkill ex:ProblemSolving .

ex:CybersecurityAnalyst_SQL_Requirement a ex:SkillRequirement ;
    ex:priority "Medium" ;
    ex:requirementForCareer ex:CybersecurityAnalyst ;
    ex:requiresSkill ex:SQL .

ex:DataAnalyst_DataVisualization_Requirement a ex:SkillRequirement ;
    ex:priority "Medium" ;
    ex:requirementForCareer ex:DataAnalyst ;
    ex:requiresSkill ex:DataVisualization .

